<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- 
      Initial Schema Setup
      Author: Antigravity
      Description: Core tables for Institution and Department
    -->

    <changeSet id="1-create-institutions" author="antigravity">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="institutions"/></not>
        </preConditions>
        <createTable tableName="institutions">
            <column name="id" type="BINARY(16)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="slug" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="email" type="VARCHAR(255)"/>
            <column name="phone" type="VARCHAR(255)"/>
            <column name="address" type="VARCHAR(255)"/>
            <column name="level" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>
            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="institutions"/>
        </rollback>
    </changeSet>

    <changeSet id="2-create-departments" author="antigravity">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="departments"/></not>
        </preConditions>
        <createTable tableName="departments">
            <column name="id" type="BINARY(16)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="institution_id" type="BINARY(16)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="code" type="VARCHAR(255)"/>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>
            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="institution_id"
                                 baseTableName="departments"
                                 constraintName="fk_department_institution"
                                 referencedColumnNames="id"
                                 referencedTableName="institutions"/>

        <createIndex indexName="idx_department_institution" tableName="departments">
            <column name="institution_id"/>
            <column name="id"/>
        </createIndex>
        <rollback>
            <dropTable tableName="departments"/>
        </rollback>
    </changeSet>
    
    <changeSet id="1.1-ensure-level-is-varchar" author="antigravity">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="institutions"/>
        </preConditions>
        <modifyDataType tableName="institutions"
                        columnName="level"
                        newDataType="VARCHAR(50)"/>
    </changeSet>

    <changeSet id="3-seed-initial-institution" author="antigravity">
        <insert tableName="institutions">
            <column name="id" valueComputed="(UNHEX(REPLACE(UUID(), '-', '')))"/>
            <column name="name" value="EduTrack Academy"/>
            <column name="slug" value="edutrack-academy"/>
            <column name="level" value="UNIVERSITY"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="is_deleted" valueBoolean="false"/>
        </insert>
        <rollback>
            <delete tableName="institutions">
                <where>slug = 'edutrack-academy'</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
