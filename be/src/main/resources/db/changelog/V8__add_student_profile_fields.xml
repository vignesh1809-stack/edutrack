<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="8-1" author="antigravity">
        <addColumn tableName="students">
            <column name="blood_group" type="VARCHAR(20)"/>
        </addColumn>
    </changeSet>

    <changeSet id="8-2" author="antigravity">
        <addColumn tableName="guardians">
            <column name="occupation" type="VARCHAR(255)"/>
            <column name="relation" type="VARCHAR(100)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
