<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="4-create-patients" author="antigravity">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="patients"/></not>
        </preConditions>
        <createTable tableName="patients">
            <column name="id" type="BINARY(16)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="institution_id" type="BINARY(16)">
                <constraints nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="date_of_birth" type="DATE"/>
            <column name="gender" type="VARCHAR(20)"/>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="institution_id"
                                 baseTableName="patients"
                                 constraintName="fk_patient_institution"
                                 referencedColumnNames="id"
                                 referencedTableName="institutions"/>
        <rollback>
            <dropTable tableName="patients"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
