<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="add-remarks-management-fields" author="antigravity">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="remarks" columnName="remark_status"/>
            </not>
        </preConditions>
        <addColumn tableName="remarks">
            <column name="remark_status" type="VARCHAR(50)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="remark_priority" type="VARCHAR(50)" defaultValue="LOW">
                <constraints nullable="false"/>
            </column>
            <column name="principal_action" type="VARCHAR(1000)"/>
            <column name="resolved_at" type="DATETIME"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
